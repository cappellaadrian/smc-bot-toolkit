# ===== Broker selection =====
# 'paper' (default, safe) or 'live' (BLOCKED unless you know what you're doing)
BROKER=paper

# Hard guard. Set to exact value below to enable live trading.
# Anything else (including unset) keeps live broker disabled.
LIVE_TRADING_EXPLICITLY_ENABLED=

# ===== BingX (only needed if BROKER=live) =====
BINGX_API_KEY=
BINGX_API_SECRET=

# ===== Supabase (state persistence) =====
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=

# ===== Telegram (alerts) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Runtime config =====
SYMBOLS=BTC-USDT,ETH-USDT
TIMEFRAME=4h
INITIAL_EQUITY=10000
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS_PCT=0.05
MAX_CONCURRENT_POSITIONS=1
LOG_LEVEL=INFO
